{
  "app-id": "io.github.tkilian.CosmicAppletWorkspaceWindows",
  "branch": "stable",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "command": "cosmic-applet-workspace-windows",
  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=xdg-config:rw",
    "--filesystem=xdg-data:ro",
    "--env=XDG_CURRENT_DESKTOP=cosmic",
    "--env=COSMIC_PANEL_OUTPUT="
  ],
  "modules": [
    {
      "name": "cosmic-applet-workspace-windows",
      "buildsystem": "simple",
      "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "env": {
          "CARGO_HOME": "/run/build/cosmic-applet-workspace-windows/cargo",
          "CARGO_NET_OFFLINE": "true",
          "RUST_BACKTRACE": "1"
        }
      },
      "build-commands": [
        "install -Dm644 cargo/config .cargo/config.toml",
        "cargo --offline fetch --manifest-path Cargo.toml --verbose",
        "cargo build --release --offline --locked",
        "install -Dm755 target/release/cosmic-applet-workspace-windows /app/bin/cosmic-applet-workspace-windows",
        "install -Dm644 data/io.github.tkilian.CosmicAppletWorkspaceWindows.desktop /app/share/applications/io.github.tkilian.CosmicAppletWorkspaceWindows.desktop",
        "install -Dm644 data/io.github.tkilian.CosmicAppletWorkspaceWindows.metainfo.xml /app/share/metainfo/io.github.tkilian.CosmicAppletWorkspaceWindows.metainfo.xml",
        "install -Dm644 data/icons/scalable/apps/io.github.tkilian.CosmicAppletWorkspaceWindows.svg /app/share/icons/hicolor/scalable/apps/io.github.tkilian.CosmicAppletWorkspaceWindows.svg"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        },
        "cargo-sources.json"
      ]
    }
  ]
}
